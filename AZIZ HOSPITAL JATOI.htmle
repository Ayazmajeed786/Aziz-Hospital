<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AHJ - Ultra 3D Medical System</title>
    <link href="https://fonts.googleapis.com" rel="stylesheet">
    <style>
        :root {
            --neon-blue: #00f2ff;
            --neon-green: #00ff88;
            --deep-bg: #050a10;
            --glass: rgba(255, 255, 255, 0.05);
            --border: rgba(255, 255, 255, 0.1);
        }

        body {
            margin: 0; padding: 0;
            font-family: 'Rajdhani', sans-serif;
            background: radial-gradient(circle at center, #102a43 0%, #050a10 100%);
            color: #e0e6ed; height: 100vh; display: flex; overflow: hidden;
        }

        /* 3D Glass Login */
        #login-screen {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.9); backdrop-filter: blur(25px);
            display: flex; justify-content: center; align-items: center; z-index: 10000;
        }
        .login-card {
            background: var(--glass); padding: 50px; border-radius: 30px;
            border: 1px solid var(--border); text-align: center;
            box-shadow: 0 0 50px rgba(0, 242, 255, 0.2); width: 400px;
            transform-style: preserve-3d; transform: perspective(1000px) rotateX(10deg);
        }
        .login-card h1 { font-family: 'Orbitron', sans-serif; color: var(--neon-blue); letter-spacing: 3px; }
        .login-card input {
            width: 100%; margin-bottom: 20px; padding: 15px; background: rgba(0,0,0,0.5);
            border: 1px solid var(--border); border-radius: 10px; color: white; text-align: center; font-size: 18px;
        }
        .login-card button {
            width: 100%; padding: 15px; border: none; border-radius: 10px;
            background: linear-gradient(90deg, var(--neon-blue), #0072ff);
            color: white; font-weight: bold; font-family: 'Orbitron'; cursor: pointer; transition: 0.3s;
        }

        /* Dashboard Layout */
        #main-app { display: none; width: 100%; height: 100vh; }
        .side-bar { 
            width: 65%; padding: 30px; overflow-y: auto; box-sizing: border-box; 
            border-right: 1px solid var(--border); background: rgba(0,0,0,0.2);
        }
        .data-panel { width: 35%; padding: 30px; box-sizing: border-box; display: flex; flex-direction: column; }

        /* 3D Cards */
        .glass-box {
            background: var(--glass); border: 1px solid var(--border);
            border-radius: 20px; padding: 25px; margin-bottom: 25px;
            box-shadow: 10px 10px 30px rgba(0,0,0,0.5); position: relative;
        }
        .glass-box::after {
            content: ''; position: absolute; top: -1px; left: -1px; width: 100%; height: 100%;
            border-radius: 20px; background: linear-gradient(45deg, transparent, rgba(0, 242, 255, 0.1), transparent);
            pointer-events: none;
        }

        h2, h3 { font-family: 'Orbitron', sans-serif; color: var(--neon-blue); text-transform: uppercase; margin-top: 0; }
        label { display: block; font-size: 12px; color: #8899a6; font-weight: 700; margin-bottom: 8px; letter-spacing: 1px; }

        .input-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
        input, select {
            width: 100%; padding: 12px; background: rgba(0,0,0,0.4); border: 1px solid var(--border);
            border-radius: 8px; color: #fff; font-size: 15px; box-sizing: border-box; transition: 0.3s;
        }
        input:focus { border-color: var(--neon-blue); box-shadow: 0 0 10px rgba(0, 242, 255, 0.3); outline: none; }

        /* Vitals Section */
        .vitals-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; }

        /* 3D Action Buttons */
        .btn-group { display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; margin-top: 20px; }
        .action-btn {
            padding: 15px; border: none; border-radius: 12px; font-weight: 700; cursor: pointer;
            text-transform: uppercase; font-family: 'Orbitron'; font-size: 10px; transition: 0.3s;
            box-shadow: 0 4px 0 rgba(0,0,0,0.5); position: relative;
        }
        .btn-save { background: #34495e; color: white; }
        .btn-print { background: var(--neon-blue); color: #000; }
        .btn-add { background: var(--neon-green); color: #000; }
        .btn-del { background: #ff4b2b; color: white; }
        .action-btn:active { transform: translateY(4px); box-shadow: none; }

        /* Table Design */
        table { width: 100%; border-collapse: separate; border-spacing: 0 10px; }
        th { text-align: left; padding: 10px; color: var(--neon-blue); font-size: 12px; border-bottom: 1px solid var(--border); }
        td { background: rgba(255,255,255,0.03); padding: 15px; font-size: 14px; }
        tr:hover td { background: rgba(0, 242, 255, 0.05); }

        .developer-footer {
            margin-top: auto; padding: 20px; text-align: center; border-radius: 15px;
            background: rgba(0, 242, 255, 0.05); border: 1px solid var(--border);
        }
    </style>
</head>
<body>

<div id="login-screen">
    <div class="login-card">
        <h1>AHJ SYSTEM</h1>
        <p style="color: #666; margin-bottom: 30px;">ULTRA 3D SECURE ACCESS</p>
        <input type="password" id="userInput" placeholder="USER ID">
        <input type="password" id="passInput" placeholder="PASSWORD">
        <button onclick="login()">AUTHORIZE SYSTEM</button>
    </div>
</div>

<div id="main-app">
    <div class="side-bar">
        <h2>🏥 AZIZ HOSPITAL JATOI</h2>
        
        <!-- Registration Details -->
        <div class="glass-box">
            <div class="input-grid">
                <div class="form-group"><label>REGISTRATION DATE</label><input type="date" id="entryDate" onchange="resetAppNo()"></div>
                <div class="form-group"><label>ENTRY TIME</label><input type="time" id="entryTime"></div>
                <div class="form-group">
                    <label>MR NUMBER (SEARCHABLE)</label>
                    <div style="display:flex; gap:10px;">
                        <input type="number" id="mrNumber" style="flex:1">
                        <button onclick="searchMR()" style="background:var(--neon-blue); border:none; width:45px; border-radius:8px; cursor:pointer">🔍</button>
                    </div>
                </div>
                <div class="form-group"><label>TOKEN / APP NO</label><input type="text" id="appNo" readonly style="color:var(--neon-green); font-weight:bold;"></div>
            </div>
        </div>

        <!-- Personal Info -->
        <div class="glass-box">
            <h3>PATIENT INFORMATION</h3>
            <div class="input-grid">
                <div class="form-group" style="grid-column: span 2;"><label>PATIENT FULL NAME</label><input type="text" id="pName" placeholder="Enter Name"></div>
                <div class="form-group"><label>CONTACT NUMBER</label><input type="text" id="contact" placeholder="03xx-xxxxxxx"></div>
                <div class="form-group"><label>CNIC / ID NUMBER</label><input type="text" id="cnic" placeholder="13-digit ID"></div>
                <div class="form-group"><label>AGE (YEARS)</label><input type="number" id="age"></div>
                <div class="form-group"><label>GENDER</label><select id="gender"><option>Male</option><option>Female</option></select></div>
            </div>
            <div style="margin-top:15px;"><label>RESIDENTIAL ADDRESS</label><input type="text" id="address" placeholder="City / Area"></div>
        </div>

        <!-- Clinical Info -->
        <div class="glass-box">
            <h3>CLINICAL DETAILS</h3>
            <div class="input-grid" style="margin-bottom:20px">
                <div class="form-group">
                    <label>CONSULTANT DOCTOR</label>
                    <select id="drName" onchange="updateFee()">
                        <option value="">-- Choose Doctor --</option>
                        <option value="Dr. Abdul Aziz SB">Dr. Abdul Aziz SB</option>
                        <option value="DR. Shahid Aziz SB">DR. Shahid Aziz SB</option>
                        <option value="Dr. Ali Naqi SB">Dr. Ali Naqi SB</option>
                        <option value="Dr. Sumaira Altaf">Dr. Sumaira Altaf</option>
                        <option value="Dr. Jawad Qasim SB">Dr. Jawad Qasim SB</option>
                    </select>
                </div>
                <div class="form-group"><label>CONSULTATION FEE (PKR)</label><input type="number" id="fee"></div>
            </div>
            <label>VITALS MONITORING</label>
            <div class="vitals-grid">
                <input type="text" id="bp" placeholder="BP (120/80)">
                <input type="text" id="temp" placeholder="Temp (°F)">
                <input type="text" id="pulse" placeholder="Pulse (BPM)">
                <input type="text" id="spo2" placeholder="SPO2 %">
            </div>
        </div>

        <div class="btn-group">
            <button class="action-btn btn-save" onclick="saveData(false)">Save Data</button>
            <button class="action-btn btn-print" onclick="saveData(true)">Save & Print</button>
            <button class="action-btn btn-add" onclick="addNew()">Add New</button>
            <button class="action-btn btn-del" onclick="deleteRecord()">Delete</button>
        </div>
    </div>

    <div class="data-panel">
        <h3>ARCHIVE FILTER</h3>
        <div class="glass-box">
            <div class="input-grid">
                <div><label>FROM</label><input type="date" id="filterFrom"></div>
                <div><label>TO</label><input type="date" id="filterTo"></div>
            </div>
            <button class="action-btn btn-print" style="width:100%; margin-top:15px" onclick="loadTable()">QUERY RECORDS</button>
        </div>

        <div style="flex:1; overflow-y:auto">
            <table id="recordTable">
                <thead><tr><th>TOKEN</th><th>MR#</th><th>NAME</th></tr></thead>
                <tbody></tbody>
            </table>
        </div>

        <div class="developer-footer">
            <span style="color:var(--neon-blue); font-family:Orbitron; font-size:14px;">AYAZ MAJEED</span><br>
            <small style="color:#555">CHIEF ARCHITECT | 0300-1199701</small>
        </div>
    </div>
</div>

<script>
    function login() {
        if (document.getElementById('userInput').value === "AHJ" && document.getElementById('passInput').value === "Ayaz786") {
            document.getElementById('login-screen').style.display = 'none';
            document.getElementById('main-app').style.display = 'flex';
        } else { alert("ACCESS DENIED: INCORRECT CREDENTIALS"); }
    }

    function updateFee() { document.getElementById('fee').value = (document.getElementById('drName').value !== "") ? 500 : ""; }

    let patients = JSON.parse(localStorage.getItem('patients')) || [];
    let mrCounter = parseInt(localStorage.getItem('mrCounter')) || 1;

    window.onload = function() {
        let now = new Date();
        document.getElementById('entryDate').valueAsDate = now;
        document.getElementById('entryTime').value = now.getHours().toString().padStart(2, '0') + ":" + now.getMinutes().toString().padStart(2, '0');
        addNew();
    };

    function addNew() {
        ['pName', 'cnic', 'contact', 'age', 'address', 'bp', 'temp', 'pulse', 'spo2', 'fee'].forEach(id => document.getElementById(id).value = '');
        document.getElementById('drName').selectedIndex = 0;
        document.getElementById('mrNumber').value = mrCounter;
        resetAppNo();
    }

    function resetAppNo() {
        let date = document.getElementById('entryDate').value;
        document.getElementById('appNo').value = patients.filter(p => p.date === date).length + 1;
    }

    function saveData(doPrint) {
        let name = document.getElementById('pName').value;
        let currentMR = parseInt(document.getElementById('mrNumber').value);
        if(!name) return alert("REQUIRED: Patient Name cannot be empty!");

        let p = {
            date: document.getElementById('entryDate').value,
            time: document.getElementById('entryTime').value,
            mr: currentMR,
            appNo: document.getElementById('appNo').value,
            name: name, contact: document.getElementById('contact').value,
            cnic: document.getElementById('cnic').value, age: document.getElementById('age').value,
            gender: document.getElementById('gender').value, address: document.getElementById('address').value,
            dr: document.getElementById('drName').value, fee: document.getElementById('fee').value,
            bp: document.getElementById('bp').value, temp: document.getElementById('temp').value,
            pulse: document.getElementById('pulse').value, spo2: document.getElementById('spo2').value
        };

        patients.push(p);
        mrCounter = Math.max(...patients.map(item => item.mr), 0) + 1;
        localStorage.setItem('patients', JSON.stringify(patients));
        localStorage.setItem('mrCounter', mrCounter);
        
        if(doPrint) {
            let type = confirm("CHOOSE PRINTER MODE:\n\nOK for THERMAL (Small)\nCancel for NORMAL (A4)");
            printSlip(p, type ? 'thermal' : 'normal');
        } else { alert("SUCCESS: Data Archived Successfully!"); }
        
        addNew();
    }

    function printSlip(p, mode) {
        let width = (mode === 'thermal') ? '300' : '750';
        let win = window.open('', '', `width=${width},height=700`);
        let containerStyle = (mode === 'thermal') ? 'width: 250px; font-size: 11px;' : 'width: 85%; font-size: 16px; margin: auto;';
        
        win.document.write(`
            <html><body style="font-family:'Courier New', monospace; padding:15px; ${containerStyle} border:2px solid #000; line-height:1.4;">
                <center>
                    <h2 style="margin:0;">AZIZ HOSPITAL JATOI</h2>
                    <p style="margin:5px 0; letter-spacing:2px;">OPD APPOINTMENT SLIP</p>
                    <hr style="border:1px dashed #000">
                </center>
                <div style="display:flex; justify-content:space-between">
                    <span><b>MR NO:</b> ${p.mr}</span> <span><b>TOKEN:</b> ${p.appNo}</span>
                </div>
                <p><b>DATE:</b> ${p.date} | <b>TIME:</b> ${p.time}</p>
                <hr style="border:1px dashed #000">
                <p><b>PATIENT:</b> ${p.name.toUpperCase()} (${p.gender}/${p.age})</p>
                <p><b>DOCTOR:</b> ${p.dr}</p>
                <p><b>VITALS:</b> BP:${p.bp} | T:${p.temp} | P:${p.pulse} | O2:${p.spo2}%</p>
                <hr style="border:1px dashed #000">
                <h3 style="text-align:right; margin:10px 0;">FEE PAID: ${p.fee} PKR</h3>
                <center style="margin-top:20px; font-size:10px;">
                    <p>*** GET WELL SOON ***</p>
                    <p>System by: Ayaz Majeed (0300-1199701)</p>
                </center>
            </body></html>
        `);
        win.document.close();
        setTimeout(() => { win.print(); win.close(); }, 500);
    }

    function searchMR() {
        let id = document.getElementById('mrNumber').value;
        let f = patients.slice().reverse().find(p => p.mr == id);
        if(f) {
            document.getElementById('pName').value = f.name;
            document.getElementById('contact').value = f.contact || '';
            document.getElementById('cnic').value = f.cnic || '';
            document.getElementById('age').value = f.age || '';
            document.getElementById('gender').value = f.gender || 'Male';
            document.getElementById('address').value = f.address || '';
            alert("RECORD FOUND: Loaded profile for " + f.name);
        } else { alert("NOT FOUND: No history for MR# " + id); }
    }

    function loadTable() {
        let tbody = document.querySelector('#recordTable tbody');
        let from = document.getElementById('filterFrom').value;
        let to = document.getElementById('filterTo').value;
        if(!from || !to) return alert("FILTER ERROR: Select Date Range!");
        
        tbody.innerHTML = '';
        patients.filter(p => p.date >= from && p.date <= to).reverse().forEach(p => {
            tbody.innerHTML += `<tr><td>${p.appNo}</td><td>${p.mr}</td><td>${p.name}</td></tr>`;
        });
    }

    function deleteRecord() {
        let id = prompt("DANGER: Enter MR# to PERMANENTLY DELETE:");
        if(id) {
            patients = patients.filter(p => p.mr != id);
            localStorage.setItem('patients', JSON.stringify(patients));
            loadTable();
            alert("DELETED: Record removed from archive.");
        }
    }
</script>
</body>
</html>
